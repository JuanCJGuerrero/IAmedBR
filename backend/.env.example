# Backend FastAPI — copie para .env e preencha os valores reais
APP_NAME=PlataformaMedicaIntegrada
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8100

DATABASE_URL=postgresql+psycopg2://postgres:SENHA@db:5432/plataforma_medica

# JWT — gere em produção: openssl rand -hex 64
JWT_SECRET=TROQUE-POR-STRING-ALEATORIA-FORTE
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost,http://localhost:3000,https://seudominio.com

