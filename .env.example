# =====================================================
# Plataforma Médica Integrada — variáveis do FRONTEND
# Copie este arquivo para .env (NUNCA versione o .env real)
# Em Vite, só variáveis com prefixo VITE_ são expostas ao bundle.
# =====================================================

# Backend principal (FastAPI + Postgres) — CRUD de pacientes/laudos
VITE_API_URL=http://localhost:8100

# Microserviço OCR (Node + Tesseract.js)
VITE_OCR_URL=http://localhost:8000

# Microserviço de IA generativa (FastAPI + Groq)
VITE_IA_URL=http://localhost:8200

# Microserviço de transcrição (FastAPI + Whisper)
VITE_TRANSCRICAO_URL=http://localhost:8300

# ----- MODO DEMO -----
# Coloque true para rodar SOMENTE o front (npm run dev) sem precisar
# de backend/Postgres/OCR/IA/Transcrição. Os dados são fake e ficam
# em memória do navegador. Login: admin@local / admin123
VITE_USE_MOCK=false
